entrypoints Exp;

TVar. Typ2 ::= Ident;
TArr. Typ1 ::= Typ2 "->" Typ1;
TAll. Typ  ::= "forall" Ident "." Typ;
coercions Exp 2;

EVar.  Exp4 ::= Ident;
EFLam. Exp3 ::= "\\" Ident ":" Typ "->" Exp3;
EFApp. Exp2 ::= Exp2 "(" Exp ")";
ETLam. Exp1 ::= "\\" Ident "->" Exp1;
ETApp. Exp  ::= Exp1 "[" Typ "]";
coercions Exp 4;