entrypoints Exp;

TNat. Typ4 ::= "ℕ";
TVar. Typ3 ::= Ident;
TArr. Typ2 ::= Typ3 "->" Typ2;
TAll. Typ1 ::= "forall" Ident "." Typ1;
coercions Typ 4;

EVar.  Exp5 ::= Ident;
EZero. Exp5 ::= "Zero";
ESucc. Exp4 ::= "Succ" Exp5;
EFApp. Exp3 ::= Exp3 Exp4;
ETApp. Exp3 ::= Exp3 "[" Typ "]";
EFLam. Exp2 ::= "λ" Ident ":" Typ "." Exp2;
ETLam. Exp2 ::= "Λ" Ident "." Exp2;
ELet.  Exp1 ::= "let" Ident ":" Typ "=" Exp2 "in" Exp;
coercions Exp 5;

comment "--" ;
comment "{-" "-}" ;
