entrypoints Exp;

TVar. Typ2 ::= Ident;
TArr. Typ1 ::= Typ1 "->" Typ2;
TAll. Typ  ::= "forall" Ident "." Typ1;
coercions Exp 2;

EVar.  Exp4 ::= Ident;
EFLam. Exp3 ::= "\\" Ident ":" Typ "->" Exp;
EFApl. Exp2 ::= Exp2 "(" Exp3 ")";
ETLam. Exp1 ::= "\\" Ident "->" Exp;
ETApp. Exp  ::= Exp "[" Typ "]";
coercions Exp 4;